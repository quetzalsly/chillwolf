// Save this as utf8 with BOM

#include <windows.h>

1 ICON "@APP_ICON@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @APP_VERSION_MAJOR@,@APP_VERSION_MINOR@,@APP_VERSION_PATCH@,0
 PRODUCTVERSION @APP_VERSION_MAJOR@,@APP_VERSION_MINOR@,@APP_VERSION_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK

#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x00L
#endif

 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP

BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "FileDescription", "@APP_DISPLAY_NAME@\0"
            VALUE "FileVersion", "@APP_VERSION@\0"
            VALUE "ProductName", "@APP_DISPLAY_NAME@\0"
            VALUE "ProductVersion", "@APP_VERSION@\0"
            VALUE "CompanyName", "@APP_DEVELOPER@\0"
            VALUE "Publisher", "@APP_PUBLISHER@\0"
            VALUE "Website", "@APP_URL@\0"
            VALUE "LegalCopyright", "@APP_COPYRIGHT@\0"
        END
    END

    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
